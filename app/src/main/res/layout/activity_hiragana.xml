<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    tools:context=".HiraganaActivity">

    <!-- Header Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/stylizedNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="あ"
            android:textColor="#3E6868"
            android:textSize="60sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/inspirationLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            android:text="Study Guide"
            android:textColor="#5E5E5E"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/stylizedNumber"
            app:layout_constraintTop_toTopOf="@id/stylizedNumber" />

        <TextView
            android:id="@+id/mainTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hiragana Chart"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/inspirationLabel"
            app:layout_constraintTop_toBottomOf="@id/inspirationLabel" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintTop_toBottomOf="@id/headerArea">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Gojuon (Basic Hiragana) -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gojuon (Basic Hiragana)" />

            <androidx.cardview.widget.CardView
                style="@style/ChartCardStyle">
                <GridLayout
                    style="@style/HiraganaGridStyle"
                    android:columnCount="6">
                    <!-- Row Header -->
                    <TextView style="@style/GridHeaderStyle" android:text="Row" />
                    <TextView style="@style/GridHeaderStyle" android:text="a" />
                    <TextView style="@style/GridHeaderStyle" android:text="i" />
                    <TextView style="@style/GridHeaderStyle" android:text="u" />
                    <TextView style="@style/GridHeaderStyle" android:text="e" />
                    <TextView style="@style/GridHeaderStyle" android:text="o" />

                    <!-- a-row -->
                    <TextView style="@style/GridLabelStyle" android:text="a" />
                    <TextView style="@style/GridCharStyle" android:text="あ\n(a)" />
                    <TextView style="@style/GridCharStyle" android:text="い\n(i)" />
                    <TextView style="@style/GridCharStyle" android:text="う\n(u)" />
                    <TextView style="@style/GridCharStyle" android:text="え\n(e)" />
                    <TextView style="@style/GridCharStyle" android:text="お\n(o)" />

                    <!-- ka-row -->
                    <TextView style="@style/GridLabelStyle" android:text="ka" />
                    <TextView style="@style/GridCharStyle" android:text="か\n(ka)" />
                    <TextView style="@style/GridCharStyle" android:text="き\n(ki)" />
                    <TextView style="@style/GridCharStyle" android:text="く\n(ku)" />
                    <TextView style="@style/GridCharStyle" android:text="け\n(ke)" />
                    <TextView style="@style/GridCharStyle" android:text="こ\n(ko)" />

                    <!-- sa-row -->
                    <TextView style="@style/GridLabelStyle" android:text="sa" />
                    <TextView style="@style/GridCharStyle" android:text="さ\n(sa)" />
                    <TextView style="@style/GridCharStyle" android:text="し\n(shi)" />
                    <TextView style="@style/GridCharStyle" android:text="す\n(su)" />
                    <TextView style="@style/GridCharStyle" android:text="せ\n(se)" />
                    <TextView style="@style/GridCharStyle" android:text="そ\n(so)" />

                    <!-- ta-row -->
                    <TextView style="@style/GridLabelStyle" android:text="ta" />
                    <TextView style="@style/GridCharStyle" android:text="た\n(ta)" />
                    <TextView style="@style/GridCharStyle" android:text="ち\n(chi)" />
                    <TextView style="@style/GridCharStyle" android:text="つ\n(tsu)" />
                    <TextView style="@style/GridCharStyle" android:text="て\n(te)" />
                    <TextView style="@style/GridCharStyle" android:text="と\n(to)" />

                    <!-- na-row -->
                    <TextView style="@style/GridLabelStyle" android:text="na" />
                    <TextView style="@style/GridCharStyle" android:text="な\n(na)" />
                    <TextView style="@style/GridCharStyle" android:text="に\n(ni)" />
                    <TextView style="@style/GridCharStyle" android:text="ぬ\n(nu)" />
                    <TextView style="@style/GridCharStyle" android:text="ね\n(ne)" />
                    <TextView style="@style/GridCharStyle" android:text="の\n(no)" />

                    <!-- ha-row -->
                    <TextView style="@style/GridLabelStyle" android:text="ha" />
                    <TextView style="@style/GridCharStyle" android:text="は\n(ha)" />
                    <TextView style="@style/GridCharStyle" android:text="ひ\n(hi)" />
                    <TextView style="@style/GridCharStyle" android:text="ふ\n(fu)" />
                    <TextView style="@style/GridCharStyle" android:text="へ\n(he)" />
                    <TextView style="@style/GridCharStyle" android:text="ほ\n(ho)" />

                    <!-- ma-row -->
                    <TextView style="@style/GridLabelStyle" android:text="ma" />
                    <TextView style="@style/GridCharStyle" android:text="ま\n(ma)" />
                    <TextView style="@style/GridCharStyle" android:text="み\n(mi)" />
                    <TextView style="@style/GridCharStyle" android:text="む\n(mu)" />
                    <TextView style="@style/GridCharStyle" android:text="め\n(me)" />
                    <TextView style="@style/GridCharStyle" android:text="も\n(mo)" />

                    <!-- ya-row -->
                    <TextView style="@style/GridLabelStyle" android:text="ya" />
                    <TextView style="@style/GridCharStyle" android:text="や\n(ya)" />
                    <TextView style="@style/GridCharStyle" android:text="—" />
                    <TextView style="@style/GridCharStyle" android:text="ゆ\n(yu)" />
                    <TextView style="@style/GridCharStyle" android:text="—" />
                    <TextView style="@style/GridCharStyle" android:text="よ\n(yo)" />

                    <!-- ra-row -->
                    <TextView style="@style/GridLabelStyle" android:text="ra" />
                    <TextView style="@style/GridCharStyle" android:text="ら\n(ra)" />
                    <TextView style="@style/GridCharStyle" android:text="り\n(ri)" />
                    <TextView style="@style/GridCharStyle" android:text="る\n(ru)" />
                    <TextView style="@style/GridCharStyle" android:text="れ\n(re)" />
                    <TextView style="@style/GridCharStyle" android:text="ろ\n(ro)" />

                    <!-- wa-row -->
                    <TextView style="@style/GridLabelStyle" android:text="wa" />
                    <TextView style="@style/GridCharStyle" android:text="わ\n(wa)" />
                    <TextView style="@style/GridCharStyle" android:text="—" />
                    <TextView style="@style/GridCharStyle" android:text="—" />
                    <TextView style="@style/GridCharStyle" android:text="—" />
                    <TextView style="@style/GridCharStyle" android:text="を\n(wo)" />

                    <!-- n -->
                    <TextView style="@style/GridLabelStyle" android:text="n" />
                    <TextView style="@style/GridCharStyle" android:text="ん\n(n)" />
                </GridLayout>
            </androidx.cardview.widget.CardView>

            <!-- Yoon (Contracted Sounds) -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yōon (Contracted Sounds)" />

            <androidx.cardview.widget.CardView
                style="@style/ChartCardStyle">
                <GridLayout
                    style="@style/HiraganaGridStyle"
                    android:columnCount="4">
                    <TextView style="@style/GridHeaderStyle" android:text="" />
                    <TextView style="@style/GridHeaderStyle" android:text="ya" />
                    <TextView style="@style/GridHeaderStyle" android:text="yu" />
                    <TextView style="@style/GridHeaderStyle" android:text="yo" />

                    <TextView style="@style/GridLabelStyle" android:text="k" />
                    <TextView style="@style/GridCharStyle" android:text="きゃ\n(kya)" />
                    <TextView style="@style/GridCharStyle" android:text="きゅ\n(kyu)" />
                    <TextView style="@style/GridCharStyle" android:text="きょ\n(kyo)" />

                    <TextView style="@style/GridLabelStyle" android:text="s" />
                    <TextView style="@style/GridCharStyle" android:text="しゃ\n(sha)" />
                    <TextView style="@style/GridCharStyle" android:text="しゅ\n(shu)" />
                    <TextView style="@style/GridCharStyle" android:text="しょ\n(sho)" />

                    <TextView style="@style/GridLabelStyle" android:text="t" />
                    <TextView style="@style/GridCharStyle" android:text="ちゃ\n(cha)" />
                    <TextView style="@style/GridCharStyle" android:text="ちゅ\n(chu)" />
                    <TextView style="@style/GridCharStyle" android:text="ちょ\n(cho)" />

                    <TextView style="@style/GridLabelStyle" android:text="n" />
                    <TextView style="@style/GridCharStyle" android:text="にゃ\n(nya)" />
                    <TextView style="@style/GridCharStyle" android:text="にゅ\n(nyu)" />
                    <TextView style="@style/GridCharStyle" android:text="にょ\n(nyo)" />

                    <TextView style="@style/GridLabelStyle" android:text="h" />
                    <TextView style="@style/GridCharStyle" android:text="ひゃ\n(hya)" />
                    <TextView style="@style/GridCharStyle" android:text="ひゅ\n(hyu)" />
                    <TextView style="@style/GridCharStyle" android:text="ひょ\n(hyo)" />

                    <TextView style="@style/GridLabelStyle" android:text="m" />
                    <TextView style="@style/GridCharStyle" android:text="みゃ\n(mya)" />
                    <TextView style="@style/GridCharStyle" android:text="みゅ\n(myu)" />
                    <TextView style="@style/GridCharStyle" android:text="みょ\n(myo)" />

                    <TextView style="@style/GridLabelStyle" android:text="r" />
                    <TextView style="@style/GridCharStyle" android:text="りゃ\n(rya)" />
                    <TextView style="@style/GridCharStyle" android:text="りゅ\n(ryu)" />
                    <TextView style="@style/GridCharStyle" android:text="りょ\n(ryo)" />
                </GridLayout>
            </androidx.cardview.widget.CardView>

            <!-- Dakuten (Voiced Sounds) -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dakuten (Voiced Sounds)" />

            <androidx.cardview.widget.CardView
                style="@style/ChartCardStyle">
                <GridLayout
                    style="@style/HiraganaGridStyle"
                    android:columnCount="6">
                    <TextView style="@style/GridHeaderStyle" android:text="Row" />
                    <TextView style="@style/GridHeaderStyle" android:text="a" />
                    <TextView style="@style/GridHeaderStyle" android:text="i" />
                    <TextView style="@style/GridHeaderStyle" android:text="u" />
                    <TextView style="@style/GridHeaderStyle" android:text="e" />
                    <TextView style="@style/GridHeaderStyle" android:text="o" />

                    <TextView style="@style/GridLabelStyle" android:text="ga" />
                    <TextView style="@style/GridCharStyle" android:text="が\n(ga)" />
                    <TextView style="@style/GridCharStyle" android:text="ぎ\n(gi)" />
                    <TextView style="@style/GridCharStyle" android:text="ぐ\n(gu)" />
                    <TextView style="@style/GridCharStyle" android:text="げ\n(ge)" />
                    <TextView style="@style/GridCharStyle" android:text="ご\n(go)" />

                    <TextView style="@style/GridLabelStyle" android:text="za" />
                    <TextView style="@style/GridCharStyle" android:text="ざ\n(za)" />
                    <TextView style="@style/GridCharStyle" android:text="じ\n(ji)" />
                    <TextView style="@style/GridCharStyle" android:text="ず\n(zu)" />
                    <TextView style="@style/GridCharStyle" android:text="ぜ\n(ze)" />
                    <TextView style="@style/GridCharStyle" android:text="ぞ\n(zo)" />

                    <TextView style="@style/GridLabelStyle" android:text="da" />
                    <TextView style="@style/GridCharStyle" android:text="だ\n(da)" />
                    <TextView style="@style/GridCharStyle" android:text="ぢ\n(ji)" />
                    <TextView style="@style/GridCharStyle" android:text="づ\n(zu)" />
                    <TextView style="@style/GridCharStyle" android:text="で\n(de)" />
                    <TextView style="@style/GridCharStyle" android:text="ど\n(do)" />

                    <TextView style="@style/GridLabelStyle" android:text="ba" />
                    <TextView style="@style/GridCharStyle" android:text="ば\n(ba)" />
                    <TextView style="@style/GridCharStyle" android:text="び\n(bi)" />
                    <TextView style="@style/GridCharStyle" android:text="ぶ\n(bu)" />
                    <TextView style="@style/GridCharStyle" android:text="べ\n(be)" />
                    <TextView style="@style/GridCharStyle" android:text="ぼ\n(bo)" />
                </GridLayout>
            </androidx.cardview.widget.CardView>

            <!-- Handakuten (P-sounds) -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Handakuten (P-sounds)" />

            <androidx.cardview.widget.CardView
                style="@style/ChartCardStyle">
                <GridLayout
                    style="@style/HiraganaGridStyle"
                    android:columnCount="6">
                    <TextView style="@style/GridHeaderStyle" android:text="Row" />
                    <TextView style="@style/GridHeaderStyle" android:text="a" />
                    <TextView style="@style/GridHeaderStyle" android:text="i" />
                    <TextView style="@style/GridHeaderStyle" android:text="u" />
                    <TextView style="@style/GridHeaderStyle" android:text="e" />
                    <TextView style="@style/GridHeaderStyle" android:text="o" />

                    <TextView style="@style/GridLabelStyle" android:text="pa" />
                    <TextView style="@style/GridCharStyle" android:text="ぱ\n(pa)" />
                    <TextView style="@style/GridCharStyle" android:text="ぴ\n(pi)" />
                    <TextView style="@style/GridCharStyle" android:text="ぷ\n(pu)" />
                    <TextView style="@style/GridCharStyle" android:text="ぺ\n(pe)" />
                    <TextView style="@style/GridCharStyle" android:text="ぽ\n(po)" />
                </GridLayout>
            </androidx.cardview.widget.CardView>

            <!-- Yoon with Dakuten / Handakuten -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yōon with Dakuten / Handakuten" />

            <androidx.cardview.widget.CardView
                style="@style/ChartCardStyle">
                <GridLayout
                    style="@style/HiraganaGridStyle"
                    android:columnCount="4">
                    <TextView style="@style/GridHeaderStyle" android:text="" />
                    <TextView style="@style/GridHeaderStyle" android:text="ya" />
                    <TextView style="@style/GridHeaderStyle" android:text="yu" />
                    <TextView style="@style/GridHeaderStyle" android:text="yo" />

                    <TextView style="@style/GridLabelStyle" android:text="g" />
                    <TextView style="@style/GridCharStyle" android:text="ぎゃ\n(gya)" />
                    <TextView style="@style/GridCharStyle" android:text="ぎゅ\n(gyu)" />
                    <TextView style="@style/GridCharStyle" android:text="ぎょ\n(gyo)" />

                    <TextView style="@style/GridLabelStyle" android:text="j" />
                    <TextView style="@style/GridCharStyle" android:text="じゃ\n(ja)" />
                    <TextView style="@style/GridCharStyle" android:text="じゅ\n(ju)" />
                    <TextView style="@style/GridCharStyle" android:text="じょ\n(jo)" />

                    <TextView style="@style/GridLabelStyle" android:text="b" />
                    <TextView style="@style/GridCharStyle" android:text="びゃ\n(bya)" />
                    <TextView style="@style/GridCharStyle" android:text="びゅ\n(byu)" />
                    <TextView style="@style/GridCharStyle" android:text="びょ\n(byo)" />

                    <TextView style="@style/GridLabelStyle" android:text="p" />
                    <TextView style="@style/GridCharStyle" android:text="ぴゃ\n(pya)" />
                    <TextView style="@style/GridCharStyle" android:text="ぴゅ\n(pyu)" />
                    <TextView style="@style/GridCharStyle" android:text="ぴょ\n(pyo)" />
                </GridLayout>
            </androidx.cardview.widget.CardView>

            <!-- Additional Letters -->
            <TextView
                style="@style/SectionHeaderStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Additional Letters (Foreign Sounds)" />

            <androidx.cardview.widget.CardView
                style="@style/ChartCardStyle">
                <GridLayout
                    style="@style/HiraganaGridStyle"
                    android:columnCount="4">
                    <TextView style="@style/GridCharStyle" android:text="ふぁ\n(fa)" />
                    <TextView style="@style/GridCharStyle" android:text="ふぃ\n(fi)" />
                    <TextView style="@style/GridCharStyle" android:text="ふぇ\n(fe)" />
                    <TextView style="@style/GridCharStyle" android:text="ふぉ\n(fo)" />
                    <TextView style="@style/GridCharStyle" android:text="ゔぁ\n(va)" />
                    <TextView style="@style/GridCharStyle" android:text="ゔぃ\n(vi)" />
                    <TextView style="@style/GridCharStyle" android:text="ゔぇ\n(ve)" />
                    <TextView style="@style/GridCharStyle" android:text="ゔぉ\n(vo)" />
                </GridLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        app:itemIconTint="#C1AB85"
        app:itemTextColor="#C1AB85"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>
