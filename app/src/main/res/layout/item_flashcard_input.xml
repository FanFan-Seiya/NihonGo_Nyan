<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/transparent_blurred_edittext"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_toStartOf="@+id/btnRemoveCard">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Front Side"
            android:textColor="#5E5E5E"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/cardFrontInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="Enter term..."
            android:textColor="#FFFFFF"
            android:textColorHint="#5E5E5E"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#40FFFFFF"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back Side"
            android:textColor="#5E5E5E"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/cardBackInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:hint="Enter definition..."
            android:textColor="#FFFFFF"
            android:textColorHint="#5E5E5E"
            android:textSize="16sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnRemoveCard"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Remove card"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="#F44336" />

</RelativeLayout>
