<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="20dp"
    tools:context=".SecondActivity">

    <!-- Header Area -->
    <TextView
        android:id="@+id/stylizedNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="学習"
        android:textColor="#3E6868"
        android:textSize="60sp"
        android:textStyle="bold"
        android:includeFontPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/inspirationLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:text="Dashboard"
        android:textColor="#5E5E5E"
        android:textSize="14sp"
        app:layout_constraintStart_toEndOf="@id/stylizedNumber"
        app:layout_constraintTop_toTopOf="@id/stylizedNumber" />

    <TextView
        android:id="@+id/mainTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Study Progress"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/inspirationLabel"
        app:layout_constraintTop_toBottomOf="@id/inspirationLabel" />

    <TextView
        android:id="@+id/referenceLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="CORE\nLEVEL"
        android:textColor="#C94E44"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/inspirationLabel" />

    <!-- Teal Hero Banner: My Flashcard Decks -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/tealHeroBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/teal_rounded_bg"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/stylizedNumber">

        <TextView
            android:id="@+id/decksTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flashcard Decks"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Decks"
            android:textColor="#1A1A1A"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/deckList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/decksTitle">

            <TextView
                android:id="@+id/tvNoDecks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No recent decks"
                android:textColor="#1A1A1A"
                android:visibility="gone"
                android:layout_marginBottom="12dp"/>

            <RelativeLayout
                android:id="@+id/layoutDeck1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <TextView
                    android:id="@+id/tvDeckName1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Common Phrases"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold" />
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/openButton1"
                    android:layout_width="60dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/button_radius_8"
                    android:text="Open"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/layoutDeck2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">
                <TextView
                    android:id="@+id/tvDeckName2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="JLPT N5 Vocabulary"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold" />
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/openButton2"
                    android:layout_width="60dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/button_radius_8"
                    android:text="Open"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />
            </RelativeLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/showAllDecks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Show All"
            android:textColor="#1A1A1A"
            android:textStyle="bold"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/deckList" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Grid -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/contentGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tealHeroBanner">

        <!-- Left Column -->
        <LinearLayout
            android:id="@+id/paletteColumn"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@+id/posterCard"
            app:layout_constraintHorizontal_weight="1"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Red Box: Quiz Results -->

            <!-- Tan Box: Study Tools -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:background="@drawable/red_rounded_bg"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUIZ RESULTS"
                    android:textColor="#1A1A1A"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNoQuizzes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="No recent quizzes"
                    android:textColor="#FFFFFF"
                    android:visibility="gone" />

                <!-- Quiz Result Slot 1 -->
                <LinearLayout
                    android:id="@+id/layoutQuiz1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvQuizName1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        tools:text="Quiz Name" />

                    <TextView
                        android:id="@+id/tvQuizDetails1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E0E0E0"
                        android:textSize="10sp"
                        tools:text="Score: 10/10 | 2023-10-27" />
                </LinearLayout>

                <!-- Quiz Result Slot 2 -->
                <LinearLayout
                    android:id="@+id/layoutQuiz2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvQuizName2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDetails2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E0E0E0"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Quiz Result Slot 3 -->
                <LinearLayout
                    android:id="@+id/layoutQuiz3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvQuizName3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDetails3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E0E0E0"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- Quiz Result Slot 4 -->
                <LinearLayout
                    android:id="@+id/layoutQuiz4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvQuizName4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvQuizDetails4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E0E0E0"
                        android:textSize="10sp" />
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="8dp"
                android:layout_weight="1"
                android:background="@drawable/tan_rounded_bg"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOOLS"
                    android:textColor="#1A1A1A"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnQuizMode"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="12dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_radius_8"
                    android:drawableTop="@drawable/ic_quiz"
                    android:drawablePadding="2dp"
                    android:paddingTop="4dp"
                    android:gravity="center"
                    android:text="Quiz Mode"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCreateFlashcard"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_radius_8"
                    android:drawableTop="@drawable/ic_flashcard"
                    android:drawablePadding="2dp"
                    android:paddingTop="4dp"
                    android:gravity="center"
                    android:text="Create Cards"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBasicAlphabet"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_radius_8"
                    android:drawableTop="@drawable/ic_alphabet"
                    android:drawablePadding="2dp"
                    android:paddingTop="4dp"
                    android:gravity="center"
                    android:text="Alphabet"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right Column: Poster Card (Lesson List) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/posterCard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="1.2"
            app:layout_constraintStart_toEndOf="@id/paletteColumn"
            app:strokeColor="#C1AB85"
            app:strokeWidth="2dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/books" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#801A1A1A" />

                <TextView
                    android:id="@+id/lessonHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="LESSON LIST"
                    android:textColor="#C1AB85"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnLessonList"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/tan_rounded_bg"
                    android:paddingHorizontal="16dp"
                    android:text="View All"
                    android:textAllCaps="false"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
